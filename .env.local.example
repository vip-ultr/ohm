# ─── PUBLIC (safe to expose to browser) ───────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_ANON_KEY=

# ─── SERVER ONLY (never expose to client) ─────────────────────────
SUPABASE_SERVICE_ROLE_KEY=

# Helius — token metadata, holders, transactions, OHLCV
# Get your key at https://dev.helius.xyz
HELIUS_API_KEY=
HELIUS_BASE_URL=https://api.helius.xyz/v0
HELIUS_RPC_URL=https://beta.helius-rpc.com

# Bags.fm — launchpad token mint list (primary token source)
# Get your key at https://dev.bags.fm
BAGSFM_API_KEY=
BAGSFM_BASE_URL=https://public-api-v2.bags.fm/api/v1

# DexScreener — price / volume / liquidity (no key required)
DEXSCREENER_BASE_URL=https://api.dexscreener.com

TWITTER_BEARER_TOKEN=

# Solscan — wallet detail, token balances, transfer history
# Free Pro API key at https://solscan.io/apis (select Free plan)
SOLSCAN_API_KEY=
